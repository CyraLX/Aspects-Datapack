{
    "type": "minecraft:multi_action",
    "title": {
        "translate": "aspects",
        "fallback": "!! Missing Resource Pack for Aspects !!"
    },
    "body": [
        {
            "type": "minecraft:plain_message",
            "width": 300,
            "contents": {
                "translate": "aspects.description",
                "fallback": "!! Missing Resource Pack for Aspects !!"
            }
        },
        {
            "type": "minecraft:plain_message",
            "width": 300,
            "contents": {
                "text": "",
                "color": "gray",
                "extra": [
                    {
                        "translate": "menu.aspects.about.version_format",
                        "color": "aqua",
                        "with": [
                            {
                                "translate": "dataPack.aspects.version_format_raw",
                                "color": "dark_aqua",
                                "with": [
                                    "1",
                                    "3",
                                    "3"
                                ]
                            }
                        ],
                        "hover_event": {
                            "action": "show_text",
                            "value": {
                                "translate": "menu.aspects.about.pack_data_format",
                                "color": "yellow",
                                "with": [
                                    {
                                        "text": "11",
                                        "color": "gold"
                                    }
                                ]
                            }
                        }
                    },
                    "\n\n",
                    {
                        "translate": "aspects.authors_format",
                        "color": "aqua",
                        "with": [
                            {
                                "translate": "aspects.authors",
                                "color": "dark_aqua"
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "actions": [
        {
            "label": {
                "translate": "extra.aspects.website_link",
                "with": [
                    {
                        "translate": "menu.aspects.about.website"
                    }
                ]
            },
            "tooltip": {
                "translate": "extra.aspects.redirects_to",
                "with": [
                    {
                        "translate": "extra.aspects.external_website"
                    }
                ]
            },
            "action": {
                "type": "minecraft:open_url",
                "url": "https://modrinth.com/datapack/corrupted-aspects"
            },
            "width": 150
        },
        {
            "label": {
                "translate": "extra.aspects.website_link",
                "with": [
                    {
                        "translate": "menu.aspects.about.issues"
                    }
                ]
            },
            "tooltip": {
                "translate": "extra.aspects.redirects_to",
                "with": [
                    {
                        "translate": "extra.aspects.external_website"
                    }
                ]
            },
            "action": {
                "type": "minecraft:open_url",
                "url": "https://github.com/CyraLX/Aspects/issues"
            },
            "width": 150
        },
        {
            "label": {
                "translate": "dialog.aspects.information.external_title"
            },
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "aspects:menu/information"
            },
            "width": 175
        },
        {
            "label": {
                "translate": "dialog.aspects.configs.external_title"
            },
            "tooltip": {
                "translate": "extra.aspects.require_permissions",
                "color": "red",
                "with": [
                    {
                        "translate": "extra.aspects.operator"
                    }
                ]
            },
            "action": {
                "type": "minecraft:run_command",
                "command": "function aspectlib:config/show_menu"
            },
            "width": 175
        },
        {
            "label": {
                "translate": "dialog.aspects.addons.external_title"
            },
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "aspects:menu/addons"
            },
            "width": 150
        },
        {
            "label": {
                "translate": "dialog.aspects.contributors.external_title"
            },
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "aspects:menu/contributors"
            },
            "width": 150
        },
        {
            "label": {
                "translate": "dialog.aspects.inspect_aspect.external_title"
            },
            "action": {
                "type": "minecraft:run_command",
                "command": "trigger aspect.check"
            },
            "width": 250
        }
    ],
    "exit_action": {
        "action": {
            "type": "minecraft:show_dialog",
            "dialog": "smithed:data_packs"
        },
        "label": {
            "translate": "gui.back"
        },
        "width": 200
    },
    "after_action": "wait_for_response"
}